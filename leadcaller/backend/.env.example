# Public Supabase project URL used by supporting integrations.
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key. Keep this server-side only.
SUPABASE_SERVICE_KEY=replace-with-service-role-key

# Async SQLAlchemy database URL for Supabase Postgres or local docker Postgres.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/leadcaller

# Zoho OAuth client id from the Zoho API console.
ZOHO_CLIENT_ID=replace-with-zoho-client-id

# Zoho OAuth client secret from the Zoho API console.
ZOHO_CLIENT_SECRET=replace-with-zoho-client-secret

# Zoho OAuth redirect URI registered with your Zoho app.
ZOHO_REDIRECT_URI=https://your-domain.example.com/oauth/zoho/callback

# Shared secret used to verify X-Zoho-Webhook-Token HMAC signatures.
ZOHO_WEBHOOK_SECRET=replace-with-zoho-webhook-secret

# Initial Zoho refresh token used to bootstrap token storage.
ZOHO_REFRESH_TOKEN=replace-with-zoho-refresh-token

# Zoho CRM API domain for your data center.
ZOHO_API_DOMAIN=https://www.zohoapis.com

# Zoho Accounts domain for your data center.
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com

# Retell API key for outbound call creation.
RETELL_API_KEY=replace-with-retell-api-key

# Retell agent id that will conduct lead qualification calls.
RETELL_AGENT_ID=replace-with-retell-agent-id

# Published Retell agent version to use. Example: v3 in Retell dashboard means 3 here.
RETELL_AGENT_VERSION=3

# Retell caller number in E.164 format.
RETELL_FROM_NUMBER=+911234567890

# Shared secret used to verify X-Retell-Signature HMAC signatures.
RETELL_WEBHOOK_SECRET=replace-with-retell-webhook-secret

# Retell endpoint used to import an Exotel/custom telephony number.
RETELL_IMPORT_PHONE_NUMBER_ENDPOINT=https://api.retellai.com/v2/import-phone-number

# Exotel account SID from API settings.
EXOTEL_ACCOUNT_SID=replace-with-exotel-account-sid

# Exotel API key from API settings.
EXOTEL_API_KEY=replace-with-exotel-api-key

# Exotel API token from API settings.
EXOTEL_API_TOKEN=replace-with-exotel-api-token

# Exotel API subdomain, for example api.in.exotel.com.
EXOTEL_SUBDOMAIN=api.in.exotel.com

# Exotel SIP trunk SID shared after trunk creation.
EXOTEL_TRUNK_SID=replace-with-exotel-trunk-sid

# Exotel DID/Exophone in E.164 format; this becomes RETELL_FROM_NUMBER after import.
EXOTEL_PHONE_NUMBER=+91XXXXXXXXXX

# Exotel SIP termination URI/domain for Retell outbound calls.
EXOTEL_TERMINATION_URI=replace-with-exotel-termination-uri

# SIP digest username configured on the Exotel trunk for Retell.
EXOTEL_SIP_AUTH_USERNAME=replace-with-sip-username

# SIP digest password configured on the Exotel trunk for Retell.
EXOTEL_SIP_AUTH_PASSWORD=replace-with-sip-password

# Exotel/Retell SIP transport. Prefer TLS.
EXOTEL_TRANSPORT=TLS

# Exotel verified caller ID or Exophone used for Calls/connect.
EXOTEL_CALLER_ID=0XXXXXXXXX

# ExoML app URL Exotel should execute for bridged calls.
EXOTEL_EXOML_URL=http://my.exotel.com/replace-with-exotel-account-sid/exoml/start_voice/replace-with-app-id

# Public callback URL for Exotel call status events.
EXOTEL_STATUS_CALLBACK=https://your-domain.example.com/webhooks/exotel/status

# Exotel call type for Calls/connect.
EXOTEL_CALL_TYPE=trans

# Public URL of this FastAPI server, used by Retell webhook callbacks.
BASE_URL=https://your-domain.example.com

# Runtime environment: dev, staging, or prod.
ENVIRONMENT=dev

# Python logging level.
LOG_LEVEL=INFO
