{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/admin/:path*",    "destination": "https://leadcaller-backend-production.up.railway.app/admin/:path*" },
    { "source": "/whatsapp/:path*", "destination": "https://leadcaller-backend-production.up.railway.app/whatsapp/:path*" },
    { "source": "/webhooks/:path*", "destination": "https://leadcaller-backend-production.up.railway.app/webhooks/:path*" },
    { "source": "/uploads/:path*",  "destination": "https://leadcaller-backend-production.up.railway.app/uploads/:path*" },
    { "source": "/health",          "destination": "https://leadcaller-backend-production.up.railway.app/health" },
    { "source": "/(.*)",            "destination": "/index.html" }
  ]
}
