{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/admin/:path*",    "destination": "https://dweller-tinkling-mutiny.ngrok-free.dev/admin/:path*" },
    { "source": "/whatsapp/:path*", "destination": "https://dweller-tinkling-mutiny.ngrok-free.dev/whatsapp/:path*" },
    { "source": "/webhooks/:path*", "destination": "https://dweller-tinkling-mutiny.ngrok-free.dev/webhooks/:path*" },
    { "source": "/uploads/:path*",  "destination": "https://dweller-tinkling-mutiny.ngrok-free.dev/uploads/:path*" },
    { "source": "/health",          "destination": "https://dweller-tinkling-mutiny.ngrok-free.dev/health" },
    { "source": "/(.*)",            "destination": "/index.html" }
  ]
}
